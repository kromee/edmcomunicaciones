# Supabase (Project Settings → API)
# URL y anon: públicas en el cliente; la anon no debe poder leer datos sensibles si RLS está bien (RLS + backend con service_role).
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anon
# Obligatoria en el servidor (Next.js API routes y Server Components). Bypassa RLS; nunca NEXT_PUBLIC_ ni uso en el navegador.
SUPABASE_SERVICE_ROLE_KEY=tu_clave_service_role

# Reemplaza los valores arriba con tus credenciales reales de EmailJS:
# 1. Ve a https://emailjs.com y crea una cuenta
# 2. Configura un servicio de email (Gmail, Outlook, etc.)
# 3. Crea un template con las variables: {{from_name}}, {{from_email}}, {{phone}}, {{company}}, {{service}}, {{message}}, {{to_email}}
# 4. Obtén tu Service ID, Template ID y Public Key
# 5. Reemplaza los valores en este archivo
